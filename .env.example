# ─── Database ─────────────────────────────────────────────────────
POSTGRES_USER=ttmm_user
POSTGRES_PASSWORD=ttmm_password
POSTGRES_DB=ttmm_database
DATABASE_URL=postgresql+asyncpg://ttmm_user:ttmm_password@db:5432/ttmm_database

# ─── LLM Agent ────────────────────────────────────────────────────
# Set USE_LLM=true to enable AI-powered agent (falls back to rule-based if false).
# Works with any OpenAI-compatible HTTP service.
#
# Option 1: qwen-code-api (local) — https://github.com/inno-se-toolkit/qwen-code-api
#   Run `qwen login` first, then start the service.
USE_LLM=true
LLM_BASE_URL=http://localhost:42005/v1
LLM_MODEL=qwen3-coder-flash # or coder-model
LLM_API_KEY=not-needed

# Option 2: DashScope (cloud)
# USE_LLM=true
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
# LLM_API_KEY=sk-xxx

# Option 3: Other OpenAI-compatible service
# USE_LLM=true
# LLM_BASE_URL=http://your-host:port/v1
# LLM_MODEL=your-model-name
# LLM_API_KEY=your-key
